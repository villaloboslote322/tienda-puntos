generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  nombre    String
  rol       String   @default("admin") // admin, super_admin
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Cliente {
  id                String         @id @default(cuid())
  nombre            String
  whatsapp          String         @unique
  dni               String         @unique
  email             String?
  cumpleaños        DateTime?
  puntosActuales    Int            @default(0)
  estado            String         @default("activo") // activo, inactivo
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  transacciones     Transaccion[]
  canjes            Canje[]

  @@map("clientes")
}

model Transaccion {
  id            String   @id @default(cuid())
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo          String   // compra, canje, bonus, ajuste
  monto         Int?     // monto en pesos de la compra (si aplica)
  puntosAsignados Int
  puntosAntes   Int
  puntosDespues Int
  descripcion   String?
  createdAt     DateTime @default(now())

  @@map("transacciones")
}

model ReglaPuntos {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  montoBase     Int      // ej: $9000
  puntosOtorgados Int    // ej: 10 puntos
  activa        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("reglas_puntos")
}

model Premio {
  id              String   @id @default(cuid())
  nombre          String
  descripcion     String?
  puntosRequeridos Int
  vigencia        DateTime?  // prize expiration date
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  canjes          Canje[]

  @@map("premios")
}

model Canje {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  premioId  String
  premio    Premio   @relation(fields: [premioId], references: [id])
  estado    String   @default("pendiente") // pendiente, completado, cancelado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("canjes")
}
